# suno-local · .env (NO commitear; .env esta en .gitignore)

# Cookie completa de un request a auth.suno.com (header "Cookie:" entero, sin
# el prefijo "Cookie: "). Suno usa Clerk v5; el host correcto es auth.suno.com.
# Como obtenerla:
#   1) Loginate en https://suno.com en Chrome
#   2) F12 → Network → recarga la pagina
#   3) Filtra por "auth.suno.com" y abre la primera request a /v1/client?...
#      (NO la del bundle JS /npm/@clerk/clerk-js@5/... — esa no lleva cookie)
#   4) Pestaña Headers → bloque Request Headers → copia el valor completo
#      del header Cookie (la linea que empieza por "__client_uat=...; __client=...")
#   5) Pegalo aqui sin comillas, todo en una linea
SUNO_COOKIE=

# Host de Clerk en Suno. Ahora mismo es auth.suno.com (Clerk v5).
# SUNO_CLERK_HOST=auth.suno.com

# Version de Clerk JS (parametro _clerk_js_version). Si Suno actualiza la mayor,
# mira en una request real a auth.suno.com/v1/... y copia el valor del query string.
SUNO_CLERK_JS_VERSION=5.0.0

# Puerto local (default 3777). Las referencias en Pixer.ai apuntan a este puerto.
# SUNO_LOCAL_PORT=3777

# Origenes permitidos para POST /generate (CSV). Pixer.ai por defecto.
# SUNO_ALLOWED_ORIGINS=https://csilvasantin.github.io,http://localhost,http://127.0.0.1

# User-Agent enviado a Suno/Clerk. Si Suno empieza a bloquear, prueba con el UA
# real de tu Chrome (chrome://version → User Agent).
# SUNO_UA=Mozilla/5.0 ...

# Base URL de la API (no tocar salvo que Suno cambie de host).
# Mayo 2026: studio-api.suno.ai esta SUSPENDIDO. El nuevo host es studio-api-prod.suno.com.
# SUNO_API_BASE=https://studio-api-prod.suno.com
